{
  "name": "lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm generate:registry && next build",
    "start": "next start",
    "lint": "oxlint -c .oxlintrc.json src/",
    "lint:fix": "oxlint --fix -c .oxlintrc.json src/",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "generate:registry": "tsx scripts/generate-registry.ts",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:knip": "knip",
    "audit": "pnpm audit --prod",
    "validate": "pnpm lint && pnpm check-types && pnpm test && pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.1.7",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "glob": "^11.0.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "knip": "^6.1.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "packageManager": "pnpm@9.0.0"
}
